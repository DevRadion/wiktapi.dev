# ── Wiktapi Environment Variables ──
# Copy this file to .env and customize for your deployment.
# These are also the defaults used by the Docker image.

# Path to the SQLite database file (used by the API server and build_indexes script)
DATA_PATH=/data/wiktionary.db

# Directory for data files (used by download_kaikki and import_data scripts)
# Subdirectory "jsonl/" will be created inside this directory for raw downloads
DATA_DIR=./data

# HTTP server port
PORT=3000

# HTTP server bind address (0.0.0.0 listens on all interfaces)
HOST=0.0.0.0