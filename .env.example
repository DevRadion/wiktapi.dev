# ── Wiktapi Environment Variables ──
# Copy this file to .env and customize for your deployment.

# ── Data ──

# Path to the SQLite database file (inside the container)
DATA_PATH=/data/wiktionary.db

# Directory for data files — JSONL downloads go in DATA_DIR/jsonl/ (inside the container)
DATA_DIR=/data

# ── Network ──

# HTTP server port
PORT=3000

# HTTP server bind address (0.0.0.0 listens on all interfaces)
HOST=0.0.0.0

# ── Volumes ──
# Docker uses a named volume "wiktapi-data" by default.
# To use a host bind mount (e.g. an existing data directory), override
# the volume in a docker-compose.override.yml file:
#
#   services:
#     api:
#       volumes:
#         - /mnt/your-storage/data:/data
#     worker:
#       volumes:
#         - /mnt/your-storage/data:/data
#