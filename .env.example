# ── Wiktapi Environment Variables ──
# Copy this file to .env and customize for your deployment.

# ── Data ──

# Path to the SQLite database file (inside the container)
DATA_PATH=/data/wiktionary.db

# Directory for data files — JSONL downloads go in DATA_DIR/jsonl/ (inside the container)
DATA_DIR=/data

# Docker volume source for persistent storage.
# Use "data" for a named Docker volume (default), or a host path for a bind mount.
# Example bind mount: /mnt/my-storage/wiktapi-data
DATA_VOLUME=data

# ── Network ──

# HTTP server port
PORT=3000

# HTTP server bind address (0.0.0.0 listens on all interfaces)
HOST=0.0.0.0